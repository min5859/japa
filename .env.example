# Supabase Postgres connection strings.
# Use the pooled connection for DATABASE_URL on Vercel and the direct connection for migrations.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Phase 5: Gemini API integration.
GEMINI_API_KEY=""

# Phase 3: market-data source. Yahoo Finance is the planned provider.
MARKET_DATA_PROVIDER="yahoo-finance"

# Supabase Auth — magic link 기반 단일 사용자 로그인.
# 프로젝트 Settings → API 에서 확인. URL은 https://[ref].supabase.co 형식.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# 매직 링크 수신을 허용할 owner 이메일. 이 주소가 아닌 사용자는 로그인 차단.
OWNER_EMAIL=""

# Magic link redirect 의 base URL. 로컬: http://localhost:3000, 운영: https://[your-domain]
NEXT_PUBLIC_APP_URL="http://localhost:3000"

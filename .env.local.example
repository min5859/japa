# ============================================================
# japa - 환경변수 템플릿
# ============================================================
# 사용법: 이 파일을 복사하여 `.env.local`로 만들고 실제 값을 채우세요.
#         `cp .env.local.example .env.local`
# 주의:   `.env.local`은 절대 git에 커밋하지 마세요. (.gitignore에 등록됨)
# ============================================================

# ------------------------------------------------------------
# Supabase (Seoul 리전 프로젝트)
# 위치: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...                       # 클라이언트 노출 OK (RLS 보호)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...                            # 서버 전용, 절대 클라이언트 노출 금지

# ------------------------------------------------------------
# Auth Allowlist
# 본인 이메일만 로그인 허용
# ------------------------------------------------------------
OWNER_EMAIL=min5859@gmail.com

# ------------------------------------------------------------
# AI 키 암호화 시크릿 (AES-256-GCM)
# 사용자가 등록한 OpenAI/Anthropic/Google/DeepSeek API 키를 DB에 저장하기 전에
# AES-256-GCM으로 암호화할 때 사용하는 마스터 키.
#
# 생성: openssl rand -hex 32          # 64자 hex (32바이트 = 256비트)
#
# ⚠️ 분실 시 저장된 모든 AI 키를 복호화할 수 없습니다.
# ⚠️ 1Password 등 별도 안전 보관 권장.
#
# 회전 시: 이전 키를 AI_KEY_ENCRYPTION_SECRET_V1 등으로 보존하고
#         새 키를 AI_KEY_ENCRYPTION_SECRET에 설정.
# ------------------------------------------------------------
AI_KEY_ENCRYPTION_SECRET=

# ------------------------------------------------------------
# Yahoo Finance
# 현재(2026-04) 인증 불필요. 향후 필요 시 추가.
# ------------------------------------------------------------
# YAHOO_API_KEY=

# ------------------------------------------------------------
# 한국은행 환율 API (선택, Phase 2 이후)
# https://ecos.bok.or.kr/api
# ------------------------------------------------------------
# BOK_API_KEY=

# ============================================================
# japa - Personal Asset Management
# ============================================================

# ------------------------------------------------------------
# Secrets & Environment (CRITICAL — never commit)
# ------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key

# ------------------------------------------------------------
# Node.js / Next.js
# ------------------------------------------------------------
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# ------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Supabase CLI (local Docker artifacts)
# ------------------------------------------------------------
supabase/.temp/
supabase/.branches/

# ------------------------------------------------------------
# Vercel
# ------------------------------------------------------------
.vercel/

# ------------------------------------------------------------
# bkit runtime artifacts (machine-generated session state)
# ------------------------------------------------------------
.bkit/audit/
.bkit/runtime/
.bkit/state/
# (.bkit/checkpoints, .bkit/decisions, .bkit/workflows는 추적 가능 — 의사결정 기록)

# ------------------------------------------------------------
# Claude Code agent memory (session-scoped, machine-generated)
# ------------------------------------------------------------
.claude/agent-memory/

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.log
tmp/
temp/
.cache/

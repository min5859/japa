generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  CHECKING
  SAVINGS
  BROKERAGE
  RETIREMENT
  TAX_ADVANTAGED
  CREDIT
  LOAN
  OTHER
}

enum AssetClass {
  CASH
  DOMESTIC_STOCK
  INTERNATIONAL_STOCK
  ETF
  BOND
  FUND
  CRYPTO
  REAL_ESTATE
  LIABILITY
  OTHER
}

enum Currency {
  KRW
  USD
  EUR
  JPY
  CNY
  GBP
  HKD
  SGD
}

model Account {
  id                      String      @id @default(cuid())
  name                    String
  institution             String?
  type                    AccountType @default(BROKERAGE)
  currency                Currency    @default(KRW)
  cashBalance             Decimal     @default(0) @db.Decimal(18, 4)
  isTaxAdvantaged         Boolean     @default(false)
  annualContributionLimit Decimal?    @db.Decimal(18, 4)
  contributionYTD         Decimal     @default(0) @db.Decimal(18, 4)
  notes                   String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  holdings                Holding[]
  dividends               Dividend[]
  groups                  AccountGroup[]

  @@index([type])
  @@index([isTaxAdvantaged])
}

// 사용자 정의 계좌 분류 — N:M (절세계좌, 해외주식 등 자유 분류)
model AccountGroup {
  id           String    @id @default(cuid())
  name         String
  description  String?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]

  @@index([displayOrder])
}

model Holding {
  id             String     @id @default(cuid())
  accountId      String
  symbol         String?
  name           String
  assetClass     AssetClass @default(ETF)
  currency       Currency   @default(KRW)
  quantity       Decimal    @default(0) @db.Decimal(24, 8)
  averageCost    Decimal    @default(0) @db.Decimal(18, 4)
  manualPrice    Decimal    @default(0) @db.Decimal(18, 4)
  manualFxRate   Decimal    @default(1) @db.Decimal(18, 8)
  dividendYield  Decimal?   @db.Decimal(8, 4)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  account        Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dividends      Dividend[]

  @@index([accountId])
  @@index([assetClass])
  @@index([symbol])
}

model PriceCache {
  symbol    String   @id
  price     Decimal  @db.Decimal(18, 4)
  currency  String   @default("USD")
  fetchedAt DateTime @default(now())
}

model MarketIndexHistory {
  symbol String
  date   DateTime @db.Date
  open   Decimal  @db.Decimal(18, 6)
  high   Decimal  @db.Decimal(18, 6)
  low    Decimal  @db.Decimal(18, 6)
  close  Decimal  @db.Decimal(18, 6)

  @@id([symbol, date])
  @@index([symbol])
}

model MarketIndex {
  symbol        String   @id
  name          String
  price         Decimal  @db.Decimal(18, 6)
  previousClose Decimal  @db.Decimal(18, 6)
  changePercent Decimal  @db.Decimal(8, 4)
  currency      String   @default("USD")
  isYield       Boolean  @default(false)
  fetchedAt     DateTime @default(now())
}

// 실제 수령 배당 내역 — 예상치(Holding.dividendYield)와 분리해 추적
model Dividend {
  id              String    @id @default(cuid())
  accountId       String
  holdingId       String?
  symbol          String?
  dividendDate    DateTime  @db.Date
  exDividendDate  DateTime? @db.Date
  amountPerShare  Decimal   @db.Decimal(18, 6)
  quantity        Decimal   @db.Decimal(24, 8)
  totalAmount     Decimal   @db.Decimal(18, 4)
  taxAmount       Decimal   @default(0) @db.Decimal(18, 4)
  netAmount       Decimal   @db.Decimal(18, 4)
  currency        Currency  @default(KRW)
  fxRate          Decimal   @default(1) @db.Decimal(18, 8)
  isTaxOverridden Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  holding Holding? @relation(fields: [holdingId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([holdingId])
  @@index([dividendDate])
  @@index([symbol])
}

// AI 분석 결과 — LLM 호출 결과 보관 (free tier quota 절약 + 시점 비교용)
model AiAnalysis {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  provider        String   // "gemini" | "openai" | "anthropic"
  model           String   // 사용된 모델명 (예: gemini-2.5-flash, gpt-4o-mini)
  summary         String
  allocations     String
  taxAdvice       String
  recommendations String
  risks           String
  netWorthAtTime  Decimal? @db.Decimal(18, 4)

  @@index([createdAt])
}

// 월별 포트폴리오 스냅샷 — 순자산 추이 차트용
model PortfolioSnapshot {
  id          String   @id @default(cuid())
  takenAt     DateTime @default(now())
  netWorth    Decimal  @db.Decimal(18, 4)
  totalAssets Decimal  @db.Decimal(18, 4)
  cash        Decimal  @db.Decimal(18, 4)
  investments Decimal  @db.Decimal(18, 4)
  liabilities Decimal  @db.Decimal(18, 4)
  // JSON 직렬화: { assetClass: value }[]
  allocation  Json

  @@index([takenAt])
}
